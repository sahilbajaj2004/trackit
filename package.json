{
  "name": "trackit",
  "displayName": "Trackit",
  "description": "Track TODO, FIXME & HACK comments across your workspace",
  "version": "0.0.1",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "trackit",
          "title": "Trackit",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "trackit": [
        {
          "id": "trackitView",
          "name": "TODOs"
        }
      ]
    },
    "commands": [
      {
        "command": "trackit.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "trackit.refresh",
          "when": "view == trackitView",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}